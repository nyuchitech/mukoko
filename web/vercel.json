{
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "framework": null,
  "rewrites": [
    { "source": "/studio", "destination": "https://mukoko.sanity.studio" },
    { "source": "/studio/(.*)", "destination": "https://mukoko.sanity.studio/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
