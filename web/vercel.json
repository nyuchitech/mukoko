{
  "framework": "nextjs",
  "redirects": [
    { "source": "/privacy", "destination": "/legal/privacy", "permanent": true },
    { "source": "/terms", "destination": "/legal/terms", "permanent": true },
    { "source": "/cookies", "destination": "/legal/cookies", "permanent": true },
    {
      "source": "/acceptable-use",
      "destination": "/legal/community-guidelines",
      "permanent": true
    },
    { "source": "/legal", "destination": "/legal/privacy", "permanent": false }
  ],
  "rewrites": [
    { "source": "/studio", "destination": "https://mukoko.sanity.studio" },
    { "source": "/studio/(.*)", "destination": "https://mukoko.sanity.studio/$1" }
  ]
}
